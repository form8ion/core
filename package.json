{
  "name": "@form8ion/core",
  "description": "core logic for form8ion tools",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "commonjs",
  "engines": {
    "node": "^22.21.0 || >=24.12"
  },
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "form8ion/core",
  "bugs": "https://github.com/form8ion/core/issues",
  "homepage": "https://www.npmjs.com/package/@form8ion/core",
  "runkitExampleFilename": "./example.js",
  "exports": {
    "require": "./lib/index.js",
    "import": "./lib/index.mjs"
  },
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "sideEffects": false,
  "scripts": {
    "pretest": "run-s build",
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "lint:engines": "ls-engines",
    "lint:gherkin": "gplint --config .gplintrc.json",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint",
    "lint:md": "remark . --frail",
    "lint:peer": "npm ls >/dev/null",
    "lint:publish": "publint --strict",
    "lint:sensitive": "ban",
    "test:unit": "run-s 'test:unit:base'",
    "test:unit:base": "npm-run-all --print-label --parallel test:unit:mocha test:unit:vitest -- --coverage",
    "test:unit:mocha": "DEBUG=any mocha 'src/**/*-test.js'",
    "test:unit:vitest": "DEBUG=any vitest run",
    "pretest:integration": "run-s build",
    "test:integration": "run-s 'test:integration:base -- --profile noWip'",
    "pretest:integration:base": "run-s build",
    "test:integration:base": "NODE_OPTIONS=--enable-source-maps DEBUG=any cucumber-js test/integration --profile base",
    "test:integration:debug": "DEBUG=test run-s test:integration",
    "test:integration:focus": "run-s 'test:integration:base -- --profile focus'",
    "test:integration:wip": "run-s 'test:integration:base -- --profile wip'",
    "prebuild": "run-s clean",
    "build": "npm-run-all --print-label --parallel build:*",
    "build:js": "rollup --config",
    "clean": "rimraf ./lib",
    "pregenerate:md": "run-s build",
    "generate:md": "remark . --output",
    "prepack": "run-s build",
    "prepare": "husky",
    "watch": "run-s 'build:js -- --watch'"
  },
  "files": [
    "example.js",
    "lib/",
    "src/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.14.1+sha512.6a8a4d67478497a2dbc6815cad72e64c43f33413717e242756047d466241ab39bee61e691683a64658e94496ec5f1a1c05e4a5ec62dcc773280dfd949443a367",
  "dependencies": {
    "@hapi/hoek": "^11.0.2",
    "@travi/cli-messages": "^1.0.5",
    "deepmerge": "^4.2.2",
    "ini": "^4.1.3",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "spdx-license-list": "6.11.0"
  },
  "devDependencies": {
    "@babel/register": "7.29.3",
    "@cucumber/cucumber": "11.3.0",
    "@form8ion/babel-preset": "1.6.154",
    "@form8ion/commitlint-config": "2.0.14",
    "@form8ion/eslint-config": "7.0.16",
    "@form8ion/eslint-config-cucumber": "1.4.1",
    "@form8ion/eslint-config-mocha": "3.0.6",
    "@form8ion/remark-lint-preset": "6.0.7",
    "@rollup/plugin-babel": "7.0.0",
    "@travi/any": "3.3.0",
    "@vitest/coverage-v8": "3.2.4",
    "ban-sensitive-files": "1.10.11",
    "chai": "4.5.0",
    "cz-conventional-changelog": "3.3.0",
    "filedirname": "3.4.0",
    "gplint": "2.5.2",
    "husky": "9.1.7",
    "lockfile-lint": "5.0.0",
    "ls-engines": "0.10.0",
    "mocha": "11.7.5",
    "mock-fs": "5.5.0",
    "npm-run-all2": "8.0.4",
    "publint": "0.3.20",
    "remark-cli": "12.0.1",
    "remark-toc": "9.0.0",
    "remark-usage": "11.0.1",
    "rimraf": "6.1.3",
    "rollup": "4.60.3",
    "rollup-plugin-auto-external": "2.0.0",
    "sinon": "22.0.0",
    "vitest": "3.2.4",
    "vitest-when": "0.10.0"
  }
}
